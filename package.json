{
  "name": "openbor-input-overlay",
  "version": "1.0.0",
  "description": "Overlay de gamepad transparente para OpenBOR y OBS",
  "main": "main.js",
  "author": "openbor-input-overlay contributors",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win --x64",
    "build:portable": "electron-builder --win portable --x64",
    "build:installer": "electron-builder --win nsis --x64"
  },
  "optionalDependencies": {
    "uiohook-napi": "^1.5.5"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.openbor.inputoverlay",
    "productName": "OpenBOR Input Overlay",
    "npmRebuild": false,
    "asarUnpack": [
      "node_modules/uiohook-napi/**/*"
    ],
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "renderer/**/*",
      "config.json",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        },
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}-${arch}.${ext}"
    },
    "nsis": {
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}